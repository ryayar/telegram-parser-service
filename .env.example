# Bot API (aiogram) - get from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Userbot (Telethon) - get from https://my.telegram.org
API_ID=12345678
API_HASH=0123456789abcdef0123456789abcdef
PHONE_NUMBER=79001234567

# Database
DB_PATH=data/database.db

# Logging
LOG_LEVEL=INFO

# Captcha: time window (minutes) after joining a group during which captchas are processed
CAPTCHA_WINDOW_MINUTES=10

# Admins: comma-separated Telegram user IDs to notify about unsolved captchas
# Example: ADMIN_IDS=[123456789,987654321]
ADMIN_IDS=[]

# Logging output: "console" — only terminal, "both" — terminal + file (logs/ directory)
LOG_OUTPUT=console
LOG_FILE_DIR=logs
